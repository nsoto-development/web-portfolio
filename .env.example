# Web3Forms access key — create at https://web3forms.com
# Safe to expose client-side; aliases your inbox email.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-access-key-here

# Google Analytics measurement ID — production only (gtag.js)
# Safe to expose client-side; omit locally to skip GA.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
